{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "description": "AI Career Assistant API and workers",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:push": "prisma db push --schema prisma/schema.prisma",
    "workers": "tsx watch src/workers/index.ts",
    "start:workers": "node dist/workers/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.0",
    "@types/pdfkit": "^0.17.5",
    "concurrently": "^9.2.1",
    "prisma": "^6.16.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bullmq": "^5.71.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "rate-limiter-flexible": "^10.0.1",
    "zod": "^4.3.6"
  }
